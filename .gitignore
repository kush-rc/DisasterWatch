# ═══════════════════════════════════════════════════════
# DisasterWatch — .gitignore
# ═══════════════════════════════════════════════════════

# ─── Dependencies ───────────────────────────────────────
node_modules/

# ─── Next.js ────────────────────────────────────────────
.next/
out/

# ─── Build / Production ────────────────────────────────
build/
dist/
*.tsbuildinfo
next-env.d.ts

# ─── Environment variables ─────────────────────────────
.env
.env.local
.env.*.local
# Keep the template:
!.env.example

# ─── Logs ───────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Python (backend) ──────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
*.egg-info/
dist/
build/

# ─── OS files ───────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── IDE / Editor ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Misc ───────────────────────────────────────────────
*.pem
.vercel
coverage/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions